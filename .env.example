# Database Configuration (Docker MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=marathon_bib_expo
DB_USERNAME=root
DB_PASSWORD=root

# MySQL Root Password (for Docker)
MYSQL_ROOT_PASSWORD=root

# Application Configuration
SERVER_PORT=8080

# JPA Configuration
DDL_AUTO=update
SHOW_SQL=true

# CORS Configuration
# Comma-separated list of allowed origins (frontend URLs)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200
# Comma-separated list of allowed HTTP methods
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
# Comma-separated list of allowed headers (* allows all)
CORS_ALLOWED_HEADERS=*
# Comma-separated list of headers to expose to the client
CORS_EXPOSED_HEADERS=Authorization,Content-Type
# Allow credentials (cookies, authorization headers)
CORS_ALLOW_CREDENTIALS=true
# Max age for preflight requests in seconds (1 hour)
CORS_MAX_AGE=3600
