# Copy to .env and fill in. The real .env is gitignored; never commit secrets.

# ===== OpenAI (the LLM) =====
# Reuse the same key your Spring app uses for OPENAI_API_KEY.
OPENAI_API_KEY=sk-your-openai-key
# Main agent model (reasoning + tool calls). See plan/AI_AGENT_MODEL_CHOICE.md.
OPENAI_MODEL=gpt-4.1
# Cheaper model used only to summarize old history (a separate TPM bucket).
OPENAI_SUMMARY_MODEL=gpt-4.1-mini
# Working token budget for one turn's context; summarization triggers at 75% of this.
# Size it to your model tier's TPM with headroom (start ~12000-16000, raise as TPM grows).
BIBEXPO_CONTEXT_BUDGET_TOKENS=16000

# ===== LangSmith (tracing; optional) =====
LANGSMITH_API_KEY=lsv2_your-langsmith-key
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT="Bib Expo Agent"

# ===== Bib Expo backend (your Spring app) =====
BIBEXPO_API_BASE_URL=http://localhost:8080
BIBEXPO_MCP_SSE_URL=http://localhost:8080/sse
# HTTP timeout (seconds) connecting to / calling the MCP server.
BIBEXPO_MCP_TIMEOUT_SECONDS=30
# Dev login the agent uses to get a JWT; every tool runs with THIS user's role.
BIBEXPO_USERNAME=root
BIBEXPO_PASSWORD=root

# How freely the agent acts before asking a human: auto | agent | ask
BIBEXPO_APPROVAL_MODE=agent

# ===== HTTP chat service (Spring calls this server-to-server) =====
BIBEXPO_API_HOST=127.0.0.1
BIBEXPO_API_PORT=8000
# Required shared secret the agent verifies on every request; must equal Spring's
# BIBEXPO_AGENT_INTERNAL_SECRET. The agent refuses to start without it.
BIBEXPO_INTERNAL_SECRET=default-agent-secret-change-in-production

# ===== DynamoDB (chat memory + token usage) =====
# Locally these point at LocalStack; in real AWS leave the endpoint empty and use the instance role.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
BIBEXPO_DDB_ENDPOINT_URL=http://localhost:4566
# Conversation checkpoints (LangGraph) and per-user daily token usage.
BIBEXPO_CHECKPOINT_TABLE=marathon-ai-agent-checkpoints
BIBEXPO_AI_USAGE_TABLE=marathon-ai-usage
